{
  "manifest_version": 3,
  "name": "Vinted Notifications Unlocker",
  "version": "1.0.0",
  "description": "Erweitert die Vinted-Benachrichtigungen mit Seiten und einstellbarer Item-Anzahl.",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://www.vinted.de/member/notifications*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.vinted.de/member/notifications*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
